# Firebase Configuration (Frontend)
# API Key do Firebase (pública, mas deve ser protegida por restrições no console)
VITE_FIREBASE_API_KEY=

# Domínio de autenticação
VITE_FIREBASE_AUTH_DOMAIN=

# ID do projeto no Firebase
VITE_FIREBASE_PROJECT_ID=

# Bucket de armazenamento (Storage)
VITE_FIREBASE_STORAGE_BUCKET=

# ID do remetente (Cloud Messaging)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ID único da aplicação
VITE_FIREBASE_APP_ID=

# Para Analytics (opcional)
VITE_FIREBASE_MEASUREMENT_ID=