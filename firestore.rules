rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isProfessor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == "professor";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Usuários
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Disciplinas
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;

      // Perguntas (subcoleção)
      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.professorId == request.auth.uid;
      }
    }

    // Sessões
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid &&
        resource.data.status == "finished";
    }

    // Jogadores da sessão
    match /session_players/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    
    // Classes (turmas)
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Matrículas
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(request.resource.data.classId))
          .data.professorId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId))
          .data.professorId == request.auth.uid;
      allow update: if false;
    }
    
    // Answers
    match /session_answers/{answerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

		// XP: 
		match /xp/{xpId} {
  		allow read: if isAuthenticated();
  	  allow create: if isAuthenticated() &&
    		request.resource.data.userId == request.auth.uid;
  		allow update, delete: if false;
		}

    // Coins:
    match /coins/{coinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Coin Balance:
    match /coin_balance/{balanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }
  }
}