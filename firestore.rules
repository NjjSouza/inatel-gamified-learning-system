rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isProfessor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == "professor";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSessionProfessor(sessionId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/sessions/$(sessionId)).data.professorId == request.auth.uid;
    }

    // Usuários
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Disciplinas
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;

      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.professorId == request.auth.uid;
      }
    }

    // Sessões
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid &&
        resource.data.status == "finished";
    }

    // Jogadores da sessão
    match /session_players/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Classes (turmas)
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Matrículas
    // Professor cria; aluno pode atualizar o próprio enrollment (vincular userId)
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(request.resource.data.classId))
          .data.professorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Professor dono da turma pode atualizar
        get(/databases/$(database)/documents/classes/$(resource.data.classId))
          .data.professorId == request.auth.uid
        ||
        // Aluno pode vincular seu próprio userId (apenas se userId ainda é null)
        (resource.data.userId == null &&
         request.resource.data.userId == request.auth.uid &&
         resource.data.email == request.auth.token.email)
      );
      allow delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId))
          .data.professorId == request.auth.uid;
    }

    // Respostas de sessão
    match /session_answers/{answerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        isSessionProfessor(resource.data.sessionId);
      allow delete: if false;
    }

    // XP
    match /xp/{xpId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isProfessor()
      );
      allow update, delete: if false;
    }

    // Coins
    match /coins/{coinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Coin Balance
    match /coin_balance/{balanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}