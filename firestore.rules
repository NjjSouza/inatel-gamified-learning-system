rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isProfessor() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == "professor";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSessionProfessor(sessionId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/sessions/$(sessionId)).data.professorId == request.auth.uid;
    }

    // Usuários
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Disciplinas
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Quizzes e suas questões
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;

      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.professorId == request.auth.uid;
      }
    }

    // Sessões
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update: if isAuthenticated() && (
        resource.data.professorId == request.auth.uid ||
        // Aluno pode apenas adicionar o próprio UID em checkinTokenUsedBy
        (
          request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["checkinTokenUsedBy"]) &&
          request.auth.uid in request.resource.data.checkinTokenUsedBy
        )
      );
      allow delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid &&
        resource.data.status == "finished";
    }

    // Jogadores da sessão
    match /session_players/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Turmas
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update, delete: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
    }

    // Matrículas
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(request.resource.data.classId))
          .data.professorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        get(/databases/$(database)/documents/classes/$(resource.data.classId))
          .data.professorId == request.auth.uid
        ||
        (
          resource.data.userId == null &&
          request.resource.data.userId == request.auth.uid &&
          resource.data.matricula ==
            get(/databases/$(database)/documents/usuarios/$(request.auth.uid))
              .data.matricula
          )
      );
      allow delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/classes/$(resource.data.classId))
          .data.professorId == request.auth.uid;
    }

    // Respostas de sessão
    match /session_answers/{answerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        isSessionProfessor(resource.data.sessionId);
      allow delete: if false;
    }

    // XP
    match /xp/{xpId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isProfessor()
      );
      allow update, delete: if false;
    }

    // Coins
    match /coins/{coinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isProfessor()
      );
      allow update, delete: if false;
    }

    // Saldo de coins
    match /coin_balance/{balanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isProfessor()
      );
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isProfessor()
      );
      allow delete: if false;
    }

    // Lojas
    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update: if isAuthenticated() &&
        resource.data.professorId == request.auth.uid;
      // Exclusão permitida apenas para lojas fechadas sem compras (validação feita no cliente)
      allow delete: if isProfessor() &&
        resource.data.professorId == request.auth.uid &&
        resource.data.status == "closed";
    }

    // Itens da loja
    match /shop_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isProfessor();
      allow update: if isAuthenticated() && isProfessor();
      // Exclusão física permitida apenas pelo professor (usada ao excluir a loja pai)
      allow delete: if isProfessor();
    }

    // Compras
    match /shop_purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Catálogo de benefícios (persistente por professor)
    // Cada professor só pode ler, criar, editar e excluir os próprios itens.
    match /shop_catalog/{catalogItemId} {
      allow read: if isAuthenticated() && isProfessor() &&
        resource.data.professorId == request.auth.uid;
      allow create: if isProfessor() &&
        request.resource.data.professorId == request.auth.uid;
      allow update: if isProfessor() &&
        resource.data.professorId == request.auth.uid;
      allow delete: if isProfessor() &&
        resource.data.professorId == request.auth.uid;
    }
  }
}